# OilBridge environment variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env file — it is gitignored.

# --- Resend (transactional email) ---
RESEND_API_KEY=re_your_resend_key_here
EMAIL_FROM=OilBridge <contact@oilbridge.eu>
ALERT_EMAIL=contact@oilbridge.eu

# --- Stripe (payments + KYC identity) ---
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_IDENTITY_PRICE_ID=

# --- Admin account ---
ADMIN_EMAIL=admin@oilbridge.eu
ADMIN_PASSWORD=change_this_to_a_strong_password

# --- Site config ---
SITE_URL=https://www.oilbridge.eu
PORT=3000
